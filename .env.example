# =====================================================
# GlobePilots Environment Variables
# Copy this file to .env.local and fill in your values
# =====================================================

# =====================================================
# Database - Supabase
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# =====================================================
# Authentication - NextAuth.js
# =====================================================
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional, for Google Sign In)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# =====================================================
# Travel APIs
# =====================================================
# TravelPayouts API
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token
TRAVELPAYOUTS_MARKER=your_travelpayouts_marker

# =====================================================
# AI APIs
# =====================================================
# DeepSeek API (primary AI provider)
DEEPSEEK_API_KEY=your_deepseek_api_key

# Claude API (fallback AI provider)
ANTHROPIC_API_KEY=your_anthropic_api_key

# =====================================================
# Email Service - Resend
# =====================================================
RESEND_API_KEY=your_resend_api_key

# =====================================================
# Cron Jobs
# =====================================================
# Secret key for authenticating cron job requests
# Generate a random secret: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# =====================================================
# Optional: SMS Notifications (Future Enhancement)
# =====================================================
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

# =====================================================
# Optional: Analytics (Future Enhancement)
# =====================================================
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# POSTHOG_API_KEY=your_posthog_api_key

# =====================================================
# Setup Instructions:
# =====================================================
# 1. Supabase:
#    - Create project at supabase.com
#    - Run both SQL files in SQL Editor:
#      - supabase-schema-enhancements.sql
#      - supabase-user-accounts-schema.sql
#    - Get URL and anon key from Settings > API
#
# 2. TravelPayouts:
#    - Sign up at travelpayouts.com
#    - Get API token from dashboard
#    - Create marker for affiliate tracking
#
# 3. DeepSeek:
#    - Sign up at deepseek.com
#    - Get API key from dashboard
#
# 4. Resend:
#    - Sign up at resend.com
#    - Verify your domain (or use onboarding domain for testing)
#    - Get API key from API Keys section
#
# 5. NextAuth:
#    - Generate NEXTAUTH_SECRET: openssl rand -base64 32
#    - Set NEXTAUTH_URL to your domain (http://localhost:3000 for dev)
#
# 6. Google OAuth (Optional):
#    - Go to Google Cloud Console
#    - Create OAuth 2.0 credentials
#    - Add authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
#
# 7. Cron Jobs:
#    - Generate CRON_SECRET: openssl rand -base64 32
#    - In Vercel, cron jobs run automatically based on vercel.json
#    - Add CRON_SECRET to both .env.local and Vercel environment variables
#
# =====================================================
